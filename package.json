{
  "name": "meet-cute",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3009",
    "build": "prisma generate && next build",
    "start": "next start -p 3009",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test:launch:pure": "node --env-file-if-exists=.env --import tsx scripts/test-launch-pure.ts",
    "test:launch:capacity": "node --env-file-if-exists=.env --import tsx scripts/test-dinner-capacity.ts",
    "test:launch:delivery": "node --env-file-if-exists=.env --import tsx scripts/test-delivery-outbox.ts",
    "test:launch:storage": "node --env-file-if-exists=.env --import tsx scripts/test-photo-storage.ts",
    "test:launch:roles": "node --env-file-if-exists=.env --import tsx scripts/test-operator-roles.ts",
    "test:launch:roles:e2e": "node --env-file-if-exists=.env --import tsx scripts/test-operator-portal.ts",
    "test:launch": "npm run test:launch:pure && npm run test:launch:capacity && npm run test:launch:delivery && npm run test:launch:storage && npm run test:launch:roles",
    "test:race": "node --env-file-if-exists=.env --import tsx scripts/test-introduction-race.ts",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "ops": "tsx scripts/operators.ts",
    "test:fixture": "tsx scripts/test-fixture.ts",
    "login-link": "tsx scripts/login-link.ts",
    "watchdog": "tsx scripts/watchdog.ts",
    "db:seed": "tsx scripts/seed.ts",
    "embed": "tsx scripts/embed.ts",
    "demo:setup": "tsx scripts/demo-setup.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@prisma/client": "^6.1.0",
    "@sentry/nextjs": "^10.67.0",
    "@vercel/blob": "^2.4.1",
    "ioredis": "^5.11.1",
    "motion": "^12.40.0",
    "next": "^16.2.11",
    "openai": "^4.77.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.11",
    "playwright": "^1.61.1",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "fast-uri": "3.1.4",
    "postcss": "$postcss",
    "sharp": "$sharp"
  }
}
