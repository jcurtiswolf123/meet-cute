// Meet Cute data model. PostgreSQL (Neon) for production, SQLite for local dev.
// (Mirrors the Airtable schema described in the relaunch plan so an Airtable
//  sync can be layered on later without a model change.)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Person {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name      String
  // Email is optional: operator-added matchees may only have a phone. Still
  // unique (Postgres allows multiple NULLs), and required in practice for anyone
  // who signs in via magic link.
  email     String?  @unique
  phone     String? // E.164 (+1...). Primary contact for the SMS intro flow.
  city      String // "NYC" | "SF"

  // role
  isOperator   Boolean @default(false)
  isAmbassador Boolean @default(false)
  isCoach      Boolean @default(false)
  status       String  @default("applicant") // applicant | active | paused | exited

  // Member self-serve opt-in: have they said "yes, start matching me"? They
  // create a profile on signup, then opt in from their dashboard to go live.
  openToMatch  Boolean @default(false)
  optedInAt    DateTime?

  // profile
  headline    String?
  bio         String?
  lookingFor  String?
  dealBreakers String?

  // socials: collected at application and viewable by the operator. Stored as
  // canonical profile URLs (see normalizeInstagram/normalizeLinkedin in sms.ts).
  linkedin    String?
  instagram   String?
  gender       String? // "woman" | "man" | "nonbinary"
  seeking      String? // comma list of genders sought
  age          Int?
  neighborhood String?

  // compliance / safety
  birthdate    DateTime? // 18+ gate, collected at application
  agreedTosAt  DateTime? // consent to Terms + Privacy at signup

  // community recommendation (collected at application): every applicant names
  // someone who can vouch for them. voucherContact is the voucher's email/phone
  // so an operator can verify; recommendation is the displayed blurb shown on the
  // profile ("Josh is fun-loving, adventurous..."). See lib/social.ts for the
  // member-to-member Vouch[] relation that powers aggregate social proof.
  voucherName    String?
  voucherContact String?
  recommendation String?

  // ambassador
  ambassadorTitle String?
  ambassadorSince DateTime?

  // coach
  coachBio String?

  // supply / provenance
  appliedAt   DateTime?
  acceptedAt  DateTime?
  fastTracked Boolean   @default(false)

  // co-pilot semantic search
  embedding String? // JSON array of floats

  referredById String?
  referredBy   Person?  @relation("Referrals", fields: [referredById], references: [id])
  referred     Person[] @relation("Referrals")

  photos  Photo[]
  prompts Prompt[]
  sessions Session[]

  blocksMade     Block[]  @relation("Blocker")
  blocksAgainst  Block[]  @relation("Blocked")
  reportsMade    Report[] @relation("Reporter")
  reportsAgainst Report[] @relation("ReportSubject")

  matchesAsA Match[] @relation("MatchA")
  matchesAsB Match[] @relation("MatchB")

  vouchesGiven    Vouch[] @relation("Voucher")
  vouchesReceived Vouch[] @relation("Subject")

  notesAuthored Note[] @relation("NoteAuthor")
  notesAbout    Note[] @relation("NoteSubject")

  invitesSent      Referral[] @relation("Inviter")
  dinnerAttendance DinnerAttendee[]

  coachingAsClient CoachingEngagement[] @relation("Client")
  coachingAsCoach  CoachingEngagement[] @relation("Coach")

  @@index([phone])
}

// Opaque, revocable session. The cookie holds a random token; we store only its
// SHA-256 hash, so a DB leak cannot be replayed as a live session. Deleting the
// row revokes the session (sign-out, account deletion, admin revoke).
model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  personId  String
  person    Person   @relation(fields: [personId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime
  userAgent String?

  @@index([personId])
  @@index([expiresAt])
}

// Magic-link login token. Single-use, short-lived, hashed at rest. Email is
// normalized (lowercased) so requests dedupe and verify can find/create the Person.
model LoginToken {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  email      String
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  consumedAt DateTime?

  @@index([email])
  @@index([expiresAt])
}

model Photo {
  id       String @id @default(cuid())
  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  url      String // app proxy path the UI renders: /api/photos/{id}.{ext}
  storageUrl String? // external object-store URL (Vercel Blob) when not on local disk
  order    Int    @default(0)
  status   String @default("approved") // pending | approved | rejected (moderation)
}

// One member blocks another: they are removed from each other's suggestions and
// visibility, in both directions.
model Block {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  blockerId String
  blockedId String
  blocker   Person   @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked   Person   @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockedId])
}

// A safety report against a member, triaged by operators.
model Report {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  reporterId String
  subjectId  String
  reporter   Person   @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  subject    Person   @relation("ReportSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  reason     String // harassment | fake | inappropriate | safety | other
  detail     String?
  status     String   @default("open") // open | reviewed | actioned | dismissed

  @@index([subjectId])
  @@index([status])
}

model Prompt {
  id       String @id @default(cuid())
  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  question String
  answer   String
  order    Int    @default(0)
}

model Match {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  personAId String
  personBId String
  personA   Person @relation("MatchA", fields: [personAId], references: [id])
  personB   Person @relation("MatchB", fields: [personBId], references: [id])

  // matchmaker who created the suggestion
  createdById String?

  // pipeline: suggested -> invited -> mutual_yes -> connected (SMS intro flow)
  // or the legacy dating path: suggested -> mutual_yes -> date_scheduled -> ... | exit
  stage String @default("suggested")

  aDecision String @default("pending") // pending | yes | pass
  bDecision String @default("pending")

  rationale     String? // optional one-liner extra: why they'd hit it off
  // SMS intro bullets describing each person, newline-separated (one bullet per
  // line). aboutPersonA describes A and is shown to B in B's invite text;
  // aboutPersonB describes B and is shown to A. Rendered as "- " bullets in SMS.
  aboutPersonA  String?
  aboutPersonB  String?
  lastActorId   String?
  stalledReason String?
  exitReason    String?

  // SMS intro flow: when each side was texted the "want an intro?" question, and
  // when the mutual connection text went out.
  notifiedAAt DateTime?
  notifiedBAt DateTime?
  connectedAt DateTime?

  // Twilio Conversations SID for the 3-way group MMS thread opened on mutual yes.
  // Null when the connection fell back to brokering numbers (no group thread).
  // Lets the operator console deep-link and attribute logged group messages.
  conversationSid String?

  // Operator follow-up: when to check back in (feedback after a connection).
  followUpAt  DateTime?

  thread     ConciergeThread?
  references Reference[]
  notes      Note[]
  introMessages IntroMessage[]

  @@unique([personAId, personBId])
}

// Transcript of the SMS introduction for a match: the per-side invite texts, the
// bot's group opener, and any messages logged from the 3-way group thread via the
// Twilio Conversations webhook. This is what the operator console renders so a
// matchmaker can monitor conversation health and jump in. Distinct from
// ConciergeMessage (the legacy dating/scheduling concierge), which is keyed to a
// ConciergeThread rather than the lightweight operator-driven intro flow.
model IntroMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  // out = sent by Meet Cute (bot/operator); in = a participant replied.
  direction String  @default("out")
  // Display label for who sent it: "bot" | "operator" | a participant's first name.
  author    String  @default("bot")
  // The participant this message is attributed to/from, when known.
  personId  String?
  body      String
  // text | invite | group_open | first_step | operator | system
  kind      String  @default("text")

  @@index([matchId])
  @@index([createdAt])
}

model Vouch {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  voucherId String
  subjectId String
  voucher   Person   @relation("Voucher", fields: [voucherId], references: [id])
  subject   Person   @relation("Subject", fields: [subjectId], references: [id])
  note      String?

  @@unique([voucherId, subjectId])
}

// Active reference: post-match "ask a mutual friend for the inside scoop"
model Reference {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  matchId     String
  match       Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  requesterId String
  friendId    String
  prompt      String
  reply       String?
  status      String   @default("requested") // requested | replied | declined
  repliedAt   DateTime?
}

model Referral {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  code         String   @unique
  inviterId    String
  inviter      Person   @relation("Inviter", fields: [inviterId], references: [id])
  inviteeEmail String?
  inviteeId    String?
  status       String   @default("open") // open | joined | accepted
  fastTrack    Boolean  @default(true)
}

model Venue {
  id    String      @id @default(cuid())
  city  String
  name  String
  area  String?
  notes String?
  partner Boolean   @default(true)
  slots VenueSlot[]
  threads ConciergeThread[]
}

model VenueSlot {
  id        String  @id @default(cuid())
  venueId   String
  venue     Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  dayOfWeek Int // 0=Sun..6=Sat
  time      String // "19:00"
  held      Boolean @default(true) // standing hold for Meet Cute
}

model ConciergeThread {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matchId String @unique
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  venueId String?
  venue   Venue?  @relation(fields: [venueId], references: [id])

  state String @default("proposing") // proposing | round2 | confirmed | stalled | handoff | post_date | closed
  round Int    @default(1)

  proposedSlots String? // JSON array of ISO datetimes
  aPick         String?
  bPick         String?
  confirmedSlot DateTime?
  holdsUntil    DateTime?
  lastNudgeAt   DateTime?

  messages ConciergeMessage[]
}

model ConciergeMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  threadId  String
  thread    ConciergeThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  direction String // out | in
  toPersonId String?
  body      String
  kind      String  @default("text") // text | propose | confirm | reminder | checkin | system
}

model Dinner {
  id        String   @id @default(cuid())
  city      String
  date      DateTime
  venue     String
  capacity  Int      @default(12)
  theme     String?
  status    String   @default("planned") // planned | open | full | done
  notes     String?
  attendees DinnerAttendee[]
}

model DinnerAttendee {
  id       String @id @default(cuid())
  dinnerId String
  personId String
  dinner   Dinner @relation(fields: [dinnerId], references: [id], onDelete: Cascade)
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  status   String @default("invited") // invited | confirmed | attended | noshow

  @@unique([dinnerId, personId])
}

model CoachingEngagement {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  clientId  String
  coachId   String
  client    Person   @relation("Client", fields: [clientId], references: [id])
  coach     Person   @relation("Coach", fields: [coachId], references: [id])
  type      String // dating | couples
  partnerId String? // for couples
  status    String   @default("active") // active | paused | done
  sessions  Int      @default(0)
  notes     String?
}

model Note {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  subjectId String
  subject   Person   @relation("NoteSubject", fields: [subjectId], references: [id])
  authorId  String?
  author    Person?  @relation("NoteAuthor", fields: [authorId], references: [id])
  matchId   String?
  match     Match?   @relation(fields: [matchId], references: [id])
  kind      String   @default("general") // rationale | postdate | general
  body      String
}
