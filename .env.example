# Database (Neon Postgres in prod; pooled URL for the app, direct URL for migrations)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# Email (magic-link sign-in + match double opt-in). Without a key, dev logs the
# link to the console.
RESEND_API_KEY=""
RESEND_FROM="Meet Cute <hello@meet-cute.app>"
RESEND_REPLY_TO=""

# Match double opt-in by email reply. When a match is made, each person gets an
# email linking to the other's profile (Yes/Pass buttons on /i/<token>) and can
# also just reply Y/N. The reply path needs a Resend Inbound domain routed to
# POST {NEXT_PUBLIC_APP_URL}/api/email/inbound. Set RESEND_INBOUND_DOMAIN to that
# domain (invite Reply-To becomes r+<token>@<domain>) and RESEND_WEBHOOK_SECRET to
# the whsec_... signing secret from the Resend webhook. Unset = the profile-page
# buttons still work; only reply-by-email is disabled.
RESEND_INBOUND_DOMAIN=""
RESEND_WEBHOOK_SECRET=""

# Public origin used to build magic-link URLs. REQUIRED in production.
NEXT_PUBLIC_APP_URL=""

# SMS (operator-driven introductions). Without these, dev logs texts to the
# console. In production set all three. Point the Twilio number's inbound webhook
# at POST {NEXT_PUBLIC_APP_URL}/api/sms/inbound so Y/N replies are captured.
# Also point the Conversations service's onMessageAdded webhook at
# POST {NEXT_PUBLIC_APP_URL}/api/sms/conversations so group-thread messages are
# logged to the operator console.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
# Optional: a Messaging Service SID enables Advanced Opt-Out + group MMS.
TWILIO_MESSAGING_SERVICE_SID=""

# Carrier selection. "twilio" (default) or "telnyx". Telnyx is the faster-to-
# approve alternative; it handles 1:1 SMS (the Y/N invite flow, opt-out, feedback)
# fully. NOTE: the 3-way group intro (Twilio Conversations masking) has no Telnyx
# equivalent, so under telnyx the app falls back to brokering numbers directly.
SMS_PROVIDER="twilio"
# Telnyx credentials (only needed when SMS_PROVIDER=telnyx). Set TELNYX_FROM to a
# 10DLC number you own, or TELNYX_MESSAGING_PROFILE_ID to let Telnyx pick from a
# number pool. TELNYX_PUBLIC_KEY (base64 Ed25519 from the Telnyx portal) verifies
# inbound webhook signatures. Point the Telnyx messaging-profile inbound webhook
# at POST {NEXT_PUBLIC_APP_URL}/api/sms/inbound.
TELNYX_API_KEY=""
TELNYX_FROM=""
TELNYX_MESSAGING_PROFILE_ID=""
TELNYX_PUBLIC_KEY=""

# Photo storage. With a Vercel Blob token, uploads go to the global blob store
# (multi-instance safe). Without it, uploads fall back to local disk (UPLOAD_DIR).
BLOB_READ_WRITE_TOKEN=""
# UPLOAD_DIR="./.uploads"

# Rate limiting across instances (falls back to in-memory when unset).
REDIS_URL=""

# Error tracking + AI fixing. No-op until set. For client-side tunnel + source
# maps, set SENTRY_DSN at build time too (Docker build arg / Fly build secret).
# The watchdog uses SENTRY_AUTH_TOKEN + ORG + PROJECT to surface unresolved
# runtime issues. Enable Sentry Seer (AI autofix PRs) in the Sentry UI. Full
# setup is in docs/OBSERVABILITY.md.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Local dev only. Shows one-click demo login picker on /login (operators + members).
# Do NOT set in production.
MEETCUTE_DEMO_LOGIN="1"
# Optional. When set, operator demo logins require this passphrase.
# STUDIO_DEMO_PASSWORD=""

# Optional. The co-pilot and embeddings degrade gracefully without these.
# With ANTHROPIC_API_KEY set, the co-pilot becomes a tool-calling agent that can
# take actions (match, invite, create events, book, moderate). Set COPILOT_TOOLS=0
# to force the deterministic command path even when a key is present.
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
# COPILOT_TOOLS="0"

# Watchdog worker (npm run watchdog). Monitors live health + typecheck + build.
# WATCHDOG_AUTOFIX=1 lets it open AI fix PRs on a branch (never touches prod).
WATCHDOG_URL="https://meet-cute.fly.dev"
WATCHDOG_ALERT_EMAIL=""
# WATCHDOG_AUTOFIX="0"
# WATCHDOG_INTERVAL_MS="300000"
